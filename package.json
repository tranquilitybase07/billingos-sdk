{
  "name": "@billingos/sdk",
  "version": "0.1.3",
  "description": "React SDK for BillingOS - billing, subscriptions, and payments (with iframe checkout)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": ["./src/styles/inject.ts", "./dist/index.mjs", "./dist/index.js"],
  "scripts": {
    "build": "tsup",
    "prepare": "pnpm build && pnpm --filter @billingos/node build",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm prepare && changeset publish"
  },
  "keywords": [
    "billing",
    "payments",
    "stripe",
    "subscriptions",
    "saas",
    "react",
    "sdk",
    "checkout",
    "customer-portal"
  ],
  "author": "BillingOS",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.26.2",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "@stripe/react-stripe-js": "^4.0.2",
    "@stripe/stripe-js": "^7.1.0",
    "@tanstack/react-query": "^5.90.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "react-shadow-scope": "^2.0.3",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@stripe/react-stripe-js": "^4.0.2",
    "@stripe/stripe-js": "^7.1.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-query": "^5.90.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.6",
    "@types/react-dom": "^19.0.3",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.68.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3"
  }
}
